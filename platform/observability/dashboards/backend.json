{
  "title": "CollectionGeek Backend",
  "uid": "cg-backend",
  "tags": ["collectiongeek", "backend"],
  "timezone": "browser",
  "schemaVersion": 39,
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "job",
        "label": "Job",
        "type": "query",
        "query": "label_values(up, job)",
        "regex": "/backend.*/",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Targets up",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 6 },
      "targets": [
        { "expr": "sum(up{job=~\"$job\"})", "legendFormat": "up", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "5xx error rate",
      "gridPos": { "x": 4, "y": 0, "w": 10, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=~\"$job\",status=~\"5..\"}[$__rate_interval])) / sum(rate(http_requests_total{job=~\"$job\"}[$__rate_interval]))",
          "legendFormat": "5xx ratio",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.05 }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "line" } }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Requests in flight",
      "gridPos": { "x": 14, "y": 0, "w": 10, "h": 6 },
      "targets": [
        {
          "expr": "sum(http_requests_in_flight{job=~\"$job\"})",
          "legendFormat": "in flight",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "min": 0 }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Request rate by route",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (route) (rate(http_requests_total{job=~\"$job\"}[$__rate_interval]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Latency quantiles",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{job=~\"$job\"}[$__rate_interval])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=~\"$job\"}[$__rate_interval])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{job=~\"$job\"}[$__rate_interval])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 }, "overrides": [] }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Backend pod restarts (increase, 1h)",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "sum by (pod) (increase(kube_pod_container_status_restarts_total{container=\"backend\"}[1h]))",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "min": 0 }, "overrides": [] }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Process memory (RSS)",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=~\"$job\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "min": 0 }, "overrides": [] }
    }
  ]
}
